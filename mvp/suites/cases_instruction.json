          "pattern": "\\A\\{\"name\":\\s*\"[^\"]*\",\\s*\"age\":\\s*\\d+,\\s*\"active\":\\s*(?:true|false)\\}\\Z",
          "mode": "must_match",
          "ignore_case": false
