# AEON Bench POD — environment configuration.
#
# You usually don't need this file at all. The ONLY required input is the model to benchmark,
# which you can pass inline:
#
#   AEON_HF_LINK=org/Your-Model  docker compose -f deploy/pod/docker-compose.yml up --build
#
# Everything else auto-defaults (mothership → https://aeon-bench.com, engine auto-detected from
# nvidia-smi, ports, and the pod's ed25519 device key is generated on first enroll). Copy this to
# .env only to override a default or set a token. See docs/run-a-benchmark.md for the walkthrough.

# ── REQUIRED (the one input) ─────────────────────────────────────────────────────────────────

# The model to benchmark, as a Hugging Face repo id or URL. The pod resolves → pulls →
# hash-verifies these weights (modelhost.resolve accepts: org/model, a full huggingface.co URL,
# org/model@<rev>, or .../tree/<rev>). This both selects the served model AND travels with the
# submission for model-identity verification (aeon_pod --hf-repo).
AEON_HF_LINK=org/Your-Model-Name

# ── OPTIONAL (sane defaults; override only if needed) ────────────────────────────────────────

# Where results are submitted. Defaults to the live public mothership; only change this to point
# at a private/test mothership. The pod enrolls its ed25519 device key here and streams the signed
# results bundle (attested via the verified HF-pull flow — see docs/run-a-benchmark.md).
AEON_MOTHERSHIP=https://aeon-bench.com

# ── ENGINE / HARDWARE ─────────────────────────────────────────────────────────────────────────

# Force the system profile. Set to `dgx-spark` on an NVIDIA DGX Spark (GB10) to make the pod's
# recipe default to the first-party `aeon-vllm-ultimate` engine (modelhost.is_dgx_spark). Leave
# empty to auto-detect from nvidia-smi.
AEON_SYSTEM=

# Pin the serving engine explicitly: vllm | aeon-vllm-ultimate | llama.cpp. Empty = auto
# (DGX Spark → aeon-vllm-ultimate when available, else vanilla vLLM; GGUF weights → llama.cpp).
# Whatever is used is recorded WITH the benchmark for reproducibility.
AEON_ENGINE=

# Human-readable hardware label recorded with the run, e.g. "NVIDIA DGX Spark GB10 128GB".
# (nvidia-smi GPU details are captured automatically on top of this label.)
AEON_HARDWARE=

# ── SERVED-MODEL ENGINE IMAGE / SERVE FLAGS ─────────────────────────────────────────────────────

# The vLLM (or DGX `aeon-vllm-ultimate`) image that serves `model-under-test` on :8000.
# TODO verify / pin a concrete tag instead of :latest for reproducibility.
AEON_VLLM_IMAGE=vllm/vllm-openai:latest
# AEON_ULTIMATE_IMAGE=ghcr.io/aeon-bench/aeon-vllm-ultimate:latest   # DGX Spark (see compose)

# Host port the OpenAI-compatible served model is exposed on (http://localhost:<port>/v1).
AEON_TARGET_PORT=8000

# Optional model-specific serve knobs (consumed if you wire them into the model-under-test
# command; the pod's derive_recipe also computes these from config.json).
AEON_MAX_MODEL_LEN=
AEON_QUANT=

# API key the harnesses + pod present to the served model. vLLM ignores it by default; any
# non-empty placeholder works for a local model.
AEON_TARGET_API_KEY=sk-local

# Hugging Face token — required only for gated/private repos (used by the pull step).
HF_TOKEN=

# ── HARNESS IMAGE / VERSION PINS ────────────────────────────────────────────────────────────────
# The compose BUILDS the three harness images locally under the exact names the pod's adapters run
# (`aeon-harness-hermes` / `-openclaw` / `-opencode` — see mvp/pod/adapters/*.py); the pod then
# launches one fresh `docker run --rm` container per agentic task. Each harness's EXACT version is
# disclosed in the report so model×harness is apples-to-apples — pin deliberately, a harness update
# can move scores. (See AGENTS.md.)

# Hermes Agent — built from source (github.com/NousResearch/hermes-agent). Pin the git ref (release
# tag or commit) so the disclosed version is reproducible. TODO verify a concrete tag exists.
AEON_HERMES_REF=main

# OpenClaw — npm package `openclaw`. TODO verify this pinned version exists on the registry.
AEON_OPENCLAW_VERSION=0.17.0

# OpenCode — npm package `opencode-ai` (CLI `opencode`). TODO verify the pinned version.
AEON_OPENCODE_VERSION=0.3.0

# ── JUDGE (subjective Tier-1 scoring) ───────────────────────────────────────────────────────────
# Policy: a FRONTIER judge OR deterministic-only — NEVER the model under test judging itself.
# Leave AEON_JUDGE empty to score only the deterministic cases (subjective Tier-1 left unscored).

AEON_JUDGE=                # frontier judge model id, e.g. a hosted Claude/GPT/Gemini id
AEON_JUDGE_URL=            # judge endpoint (defaults to --target if empty — only valid for a frontier target)
AEON_JUDGE_KEY=            # judge API key

# ── RUN KNOBS ───────────────────────────────────────────────────────────────────────────────────

# Generation cap. Reasoning models need headroom; 2048 is the pod default.
AEON_MAX_TOKENS=2048

# Benchmark only the first N cases — a quick smoke before a full run. Empty = full suite.
AEON_LIMIT=

# Keep the verified weights after the run (1) or let them be cleaned up (0). The `weights` volume
# persists regardless; set 0 if you plan to prune it between models.
AEON_KEEP_WEIGHTS=1
